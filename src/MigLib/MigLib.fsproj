<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>

    <PackageId>MigLib</PackageId>
    <Version>5.2.2</Version>
    <PackageOutputPath>./nupkg</PackageOutputPath>
    <AssemblyName>MigLib</AssemblyName>

    <Authors>Luis Ángel Méndez Gort</Authors>
    <PackageProjectUrl>https://github.com/lamg/migrate</PackageProjectUrl>
    <RepositoryUrl>https://github.com/lamg/migrate</RepositoryUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <PackageIcon>logo.png</PackageIcon>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="AssemblyInfo.fs" />
    <Compile Include="Util.fs" />
    <Compile Include="Db.fs" />
    <Compile Include="DeclarativeMigrations/Types.fs" />
    <Compile Include="DeclarativeMigrations/SchemaDiff.fs" />
    <Compile Include="DeclarativeMigrations/DataCopy.fs" />
    <Compile Include="DeclarativeMigrations/DrainReplay.fs" />
    <Compile Include="SchemaReflection/Types.fs" />
    <Compile Include="SchemaReflection/NamingAndTypeMapping.fs" />
    <Compile Include="SchemaReflection/AttributeReaders.fs" />
    <Compile Include="SchemaReflection/TableReflection.fs" />
    <Compile Include="SchemaReflection/ViewReflection.fs" />
    <Compile Include="SchemaReflection/UnionExtensions.fs" />
    <Compile Include="SchemaReflection/SchemaAssembly.fs" />
    <Compile Include="SchemaReflection/SeedReflection.fs" />
    <Compile Include="SchemaReflection.fs" />
    <Compile Include="CodeGen/FabulousAstHelpers.fs" />
    <Compile Include="CodeGen/AstExprBuilders.fs" />
    <Compile Include="CodeGen/ViewIntrospection.fs" />
    <Compile Include="CodeGen/TypeGenerator.fs" />
    <Compile Include="CodeGen/NormalizedSchema.fs" />
    <Compile Include="CodeGen/NormalizedTypeGenerator.fs" />
    <Compile Include="CodeGen/NormalizedQueryGenerator.fs" />
    <Compile Include="CodeGen/QueryGenerator.fs" />
    <Compile Include="CodeGen/CodeGen.fs" />
    <Compile Include="HotMigration/Primitives.fs" />
    <Compile Include="HotMigration/Metadata.fs" />
    <Compile Include="HotMigration/SchemaBootstrap.fs" />
    <Compile Include="HotMigration/SchemaIntrospection.fs" />
    <Compile Include="HotMigration/Copy.fs" />
    <Compile Include="HotMigration/Planning.fs" />
    <Compile Include="HotMigration/Operations/Types.fs" />
    <Compile Include="HotMigration/Operations/Shared.fs" />
    <Compile Include="HotMigration/Operations/Reporting.fs" />
    <Compile Include="HotMigration/Operations/Migration.fs" />
    <Compile Include="HotMigration/Operations/Admin.fs" />
    <Compile Include="HotMigration/Operations.fs" />
    <Compile Include="CompiledSchema.fs" />
    <Compile Include="Build.fs" />
    <Content Include="../../README.md" Pack="true" PackagePath="\" />
    <Content Include="../../images/logo.png" Pack="true" PackagePath="\" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Fabulous.AST" />
    <PackageReference Include="Fantomas.Core" />
    <PackageReference Include="FSharp.Core" />
    <PackageReference Include="Microsoft.Data.Sqlite" />
  </ItemGroup>
</Project>
